{
  "name": "NORDIQ20",
  "version": "1.0.0",
  "private": true,
  "description": "NORDIQ-20 — Indice Canadien",
  "type": "module",
  "scripts": {
    "update": "tsx src/scripts/update.ts",
    "update:backtest": "tsx src/scripts/update.ts --name backtest",
    "update:revised": "tsx src/scripts/update.ts --name revised",
    "update:na": "tsx src/scripts/update.ts --name na",
    "backfill": "tsx src/scripts/backfill.ts",
    "backfill:backtest": "tsx src/scripts/backfill.ts --name backtest --from 2021-06-30",
    "backfill:revised": "tsx src/scripts/backfill.ts --name revised",
    "backfill:na": "tsx src/scripts/backfill.ts --name na",
    "rebalance": "tsx src/scripts/rebalance.ts",
    "screen": "tsx src/scripts/screen.ts",
    "screen:na": "tsx src/scripts/screen.ts --na",
    "verify-tickers": "tsx src/scripts/verify-tickers.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "build:local": "npm run build --workspace=web && tsx src/scripts/sync-dist.ts",
    "sync-data": "tsx src/scripts/sync-dist.ts",
    "sync-data:backtest": "tsx src/scripts/sync-dist.ts --name backtest",
    "sync-data:revised": "tsx src/scripts/sync-dist.ts --name revised",
    "sync-data:na": "tsx src/scripts/sync-dist.ts --name na"
  },
  "workspaces": [
    "web"
  ],
  "dependencies": {
    "yahoo-finance2": "^3.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
