{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "paths": {
      "@data/*": ["./data/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "web", "dist"]
}
